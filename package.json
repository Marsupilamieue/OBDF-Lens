{
  "name": "obdf-lens",
  "displayName": "OBDF Lens",
  "description": "Validate OBDA mappings and Teiid VDB definitions against your physical database that catch errors before runtime.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Linters"
  ],
  "activationEvents": [
    "onLanguage:obda",
    "onLanguage:xml",
    "workspaceContains:**/*.obda",
    "workspaceContains:**/vdb.xml"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "obda",
        "extensions": [
          ".obda"
        ],
        "aliases": [
          "OBDA Mapping",
          "obda"
        ]
      }
    ],
    "commands": [
      {
        "command": "obdf-lens.validate",
        "title": "OBDF Lens: Validasi Semua File"
      }
    ],
    "configuration": {
      "title": "OBDF Lens",
      "properties": {
        "obdf-lens.connections": {
          "type": "object",
          "default": {},
          "description": "Koneksi database fisik per nama source. Key = nama source di vdb.xml (e.g. 'bansos_db').",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "host": {
                "type": "string",
                "default": "localhost"
              },
              "port": {
                "type": "number",
                "default": 5432
              },
              "database": {
                "type": "string"
              },
              "user": {
                "type": "string"
              },
              "password": {
                "type": "string"
              }
            },
            "required": [
              "host",
              "port",
              "database",
              "user",
              "password"
            ]
          }
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "generate:parser": "tspeg src/parsers/obda.peg src/parsers/obdaParserGenerated.ts",
    "compile": "npm run generate:parser && tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "fast-xml-parser": "^5.8.0",
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/pg": "^8.11.11",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "tspeg": "^3.3.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
